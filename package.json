{
  "name": "react-native-rate-app",
  "version": "2.0.1",
  "description": "React Native module for In App Rating on Android and iOS",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json",
    "./app.plugin.js": "./app.plugin.js"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*",
    "app.plugin.js"
  ],
  "scripts": {
    "example": "yarn workspace react-native-rate-app-example",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "test": "jest",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "release": "semantic-release"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "rate",
    "review",
    "native",
    "store",
    "huawei",
    "samsung",
    "amazon"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huextrat/react-native-rate-app.git"
  },
  "author": "Hugo Extrat <extrat.h@gmail.com> (https://github.com/huextrat)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/huextrat/react-native-rate-app/issues"
  },
  "homepage": "https://github.com/huextrat/react-native-rate-app#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/compat": "2.0.5",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.35.0",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/eslint-config": "0.85.2",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@types/jest": "29.5.14",
    "@types/react": "19.1.12",
    "commitlint": "20.5.2",
    "del-cli": "7.0.0",
    "eslint": "9.35.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "expo": "55.0.18",
    "jest": "29.7.0",
    "prettier": "3.8.3",
    "react": "19.2.0",
    "react-native": "0.84.1",
    "react-native-builder-bob": "0.41.0",
    "semantic-release": "25.0.3",
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.14.1",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RateAppSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.rateapp"
    }
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/setupJest.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "!src/types.ts",
      "!src/NativeRateApp.ts"
    ],
    "collectCoverage": true
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "tools": [
      "jest",
      "eslint"
    ],
    "version": "0.57.2"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
